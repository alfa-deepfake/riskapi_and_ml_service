# Host port overrides for busy/shared hosts. Copy to `.env` (auto-loaded by
# docker compose) and set only what you need. Internal service-to-service ports
# never change, so ml->risk stays wired regardless of these.
#
# On cluster bc-a100-08, 8000/8001 are taken, so risk-api is published on 8002:
#   RISK_API_PORT=8002
#
# FRONTEND_PORT=8080
# ML_PORT=8100          # also edit frontend/config.js + rebuild the frontend image
# RISK_API_PORT=8000
# MONGO_PORT=27017
